## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Release]/
[Re]leasePublic/
x64/
x86/
build/
bld/
[Bin]/
[Obj]/
bin/
obj/
Generated Files/
My Project/

# MSTest Resolve Assembly Reference Cache
*.cache

# Microsoft Fakes
FakesAssemblies/

# GhostDoc Local Rules project file
*.GhostDoc.xml

# Visual Studio Code
.vscode/

# Rider
.idea/

# Visual Studio cache files
.vs/
